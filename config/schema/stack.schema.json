{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal Elastic Stack POC site configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["hostFqdn", "proxy"],
  "properties": {
    "$schema": { "type": "string" },
    "hostFqdn": {
      "allOf": [{ "$ref": "#/$defs/fqdn" }],
      "description": "Existing RHEL VM FQDN shared by Elasticsearch, Kibana, and Fleet Server"
    },
    "proxy": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["url"],
          "properties": {
            "url": {
              "type": ["string", "null"],
              "description": "Credential-free HTTP(S) proxy origin, for example http://proxy.corp.example:8080"
            },
            "noProxy": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true,
              "description": "Optional additional hosts, domain suffixes, IPs, or CIDRs that bypass the proxy"
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "fqdn": {
      "type": "string",
      "pattern": "^(?=.{1,253}$)([A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9][A-Za-z0-9-]{0,62}$"
    }
  }
}
