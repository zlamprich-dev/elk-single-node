[Unit]
Description=ELK POC Fleet Server
Requires=elk-poc-elasticsearch.service elk-poc-kibana.service
After=elk-poc-elasticsearch.service elk-poc-kibana.service

[Container]
ContainerName=elk-poc-fleet-server
Image=@@FLEET_SERVER_IMAGE@@
Network=elk-poc.network
NetworkAlias=@@FLEET_FQDN@@
PublishPort=@@BIND_ADDRESS@@:@@FLEET_PORT@@:8220
Volume=@@RUNTIME_ROOT@@/pki/fleet:/etc/elk-pki:ro,Z
Volume=@@RUNTIME_ROOT@@/data/fleet-server:/state:Z
Secret=elk_poc_fleet_service_token,type=mount,target=fleet_service_token
Environment=FLEET_SERVER_ENABLE=1
Environment=FLEET_SERVER_POLICY_ID=@@FLEET_SERVER_POLICY_ID@@
Environment=FLEET_SERVER_ELASTICSEARCH_HOST=https://@@ELASTICSEARCH_FQDN@@:@@ELASTICSEARCH_PORT@@
Environment=FLEET_SERVER_ELASTICSEARCH_CA=/etc/elk-pki/service-ca-chain.pem
Environment=FLEET_SERVER_SERVICE_TOKEN_PATH=/run/secrets/fleet_service_token
Environment=FLEET_SERVER_CERT=/etc/elk-pki/fleet-server.crt
Environment=FLEET_SERVER_CERT_KEY=/etc/elk-pki/fleet-server.key
Environment=FLEET_SERVER_PORT=8220
Environment=FLEET_URL=https://@@FLEET_FQDN@@:@@FLEET_PORT@@
Environment=FLEET_CA=/etc/elk-pki/service-ca-chain.pem
Environment=STATE_PATH=/state
@@PROXY_CA_ENV@@
Environment=HTTP_PROXY=@@PROXY_URL@@
Environment=HTTPS_PROXY=@@PROXY_URL@@
Environment=NO_PROXY=@@NO_PROXY@@
Environment=TZ=UTC
Memory=@@FLEET_MEMORY@@
LogDriver=journald
NoNewPrivileges=true

[Service]
Restart=on-failure
RestartSec=15
TimeoutStartSec=300
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
